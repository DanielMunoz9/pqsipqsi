# Variables de entorno para Valhala Cybersecurity Lab
# Copia este archivo como .env y configura tus valores reales

# Supabase Configuration
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=tu-supabase-anon-key-aqui

# JWT Secret para el panel admin
JWT_SECRET=tu-jwt-secret-muy-seguro-aqui-min-32-caracteres

# Puerto del servidor (opcional, default 8080)
PORT=8080
